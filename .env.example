# Primær URL — skal matche AdSense og Vercel primary domain (skatehub.dk, ikke www)
NEXT_PUBLIC_SITE_URL=https://skatehub.dk

# Google Analytics 4 (valgfrit)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google AdSense — publisher-script (kræves for ads.txt + Google-verificering)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-7373148222153531

# Slå annonce-slots til EFTER Google har godkendt sitet (kræver også cookie-samtykke)
NEXT_PUBLIC_ADSENSE_ACTIVE=false
